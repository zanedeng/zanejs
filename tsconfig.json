{
    "compilerOptions": {
        "target": "es5",
        "allowJs": false,
        "sourceMap": true,
        "removeComments": false,
        "strict": true,
        "noImplicitAny": true,
        "noUnusedLocals": false,
        "noUnusedParameters": true,
        "noImplicitReturns": true,
        "strictNullChecks": false,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "baseUrl": "./",
        "paths": {
            "@zanejs/*": [
                "packages/*/src"
            ],
            "zanejs": [
                "bundles/zanejs/src"
            ]
        },
        "outDir": "./out",
        "declaration": true
    },
    "exclude": [
        "node_modules",
        "**/dist/**",
        "**/lib/**",
        "**/test/**",
        "**/scripts/**",
        "**/types/**",
        "bundles/**/*.d.ts",
        "webpack.config.js"
    ]
}
