{
    "tags": {
        "allowUnknownTags": false
    },
    "source": {
        "includePattern": [
            "packages/*/src/**/*.ts",
            "bundles/zanejs/src/*.ts"
        ],
        "excludePattern": "(node_modules|lib|test)"
    },
    "plugins": [
        "plugins/markdown"
    ],
    "template": {
        "outputSourceFiles": true,
        "readme": "./README.md",
        "repository": "https://github.com/zanedeng/zanejs/"
    },
    "templates": {
        "cleverLinks"   : false,
        "monospaceLinks": false,
        "default"       : {
            "outputSourceFiles" : true
        },
        "applicationName": "zanejs",
        "footer"        : "Made with ♥ by zane.deng (zanejs.com)",
        "copyright"     : "zanejs Copyright © 2013-2020 zane.deng.",
        "disqus": "",
        "googleAnalytics": "",
        "openGraph": {
            "title": "",
            "type": "website",
            "image": "",
            "site_name": "",
            "url": ""
        },
        "meta": {
            "title": "zanejs API Documentation",
            "description": "Documentation for zanejs library",
            "keyword": "docs, documentation, zanejs, html5, javascript, jsdoc"
        },
        "linenums"      : true
    },
    "plugin/markdown"  : {
        "parser"        : "gfm",
        "hardwrap"      : false
    },
    "opts": {
        "encoding"      : "utf8",
        "recurse"       : true,
        "lenient"       : true,
        "destination"   : "./dist/docs",
        "template"      : "zane-webdoc-template",
        "export"        : "./dist/docs/zanejs.api.json"
    }
}
